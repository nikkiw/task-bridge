FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS builder

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

WORKDIR /app

# Copy the entire task-bridge source tree
COPY . /app/source

# Install dependencies using 'uv sync --no-editable' to ensure local packages 
# are copied into the virtualenv, not just symlinked.
WORKDIR /app/source/examples/fastapi-host
RUN uv sync --no-dev --no-editable --frozen

FROM python:3.12-slim-bookworm

WORKDIR /app

# Copy the virtual environment from the builder
COPY --from=builder /app/source/examples/fastapi-host/.venv /app/.venv

# Copy the application code
COPY examples/fastapi-host/app /app/app

# Set environment variables to use the virtualenv
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app"
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

# Use python -m uvicorn to ensure we use the venv's python and site-packages
CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
