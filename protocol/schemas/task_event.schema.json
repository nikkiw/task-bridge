{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskEvent",
  "description": "TaskBridge event envelope delivered through polling or WebSocket streaming.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "TASK_STARTED",
        "TASK_PROGRESS",
        "TASK_MESSAGE",
        "TASK_SUSPENDED",
        "TASK_ACTION_ACCEPTED",
        "TASK_COMPLETED",
        "TASK_FAILED",
        "TASK_CANCELLED"
      ]
    },
    "taskId": {
      "type": "string"
    },
    "eventId": {
      "type": "string",
      "description": "Monotonic event checkpoint within a single task stream."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": [
    "type",
    "taskId",
    "eventId",
    "createdAt",
    "payload"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_SUSPENDED"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "suspendId",
              "kind",
              "reasonCode",
              "allowedActions",
              "schemaVersion"
            ],
            "properties": {
              "suspendId": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "USER_ACTION_REQUIRED",
                  "EXTERNAL_CONFIRMATION_PENDING",
                  "SYSTEM_PAUSED"
                ]
              },
              "reasonCode": {
                "type": "string"
              },
              "allowedActions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "schemaVersion": {
                "type": "integer",
                "minimum": 1
              },
              "expiresAt": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "uiHints": {
                "type": "object"
              },
              "interaction": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_ACTION_ACCEPTED"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "suspendId",
              "clientActionId",
              "actionType",
              "acceptedAt"
            ],
            "properties": {
              "suspendId": {
                "type": "string"
              },
              "clientActionId": {
                "type": "string"
              },
              "actionType": {
                "type": "string"
              },
              "acceptedAt": {
                "type": "string",
                "format": "date-time"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_STARTED"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_PROGRESS"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "progress"
            ],
            "properties": {
              "progress": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "stage": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_MESSAGE"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "message"
            ],
            "properties": {
              "message": {
                "type": "string"
              },
              "level": {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "debug"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_COMPLETED"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "result"
            ],
            "properties": {
              "result": {}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_FAILED"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "message",
              "retryable"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "retryable": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "TASK_CANCELLED"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "reason"
            ],
            "properties": {
              "reason": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  ]
}
